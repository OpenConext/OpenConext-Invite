#!/bin/bash

for tool in curl jq grep cut date; do
    if ! command -v "$tool" &> /dev/null; then
        echo "Fout: '$tool' is niet geïnstalleerd. Installeer deze tool om door te gaan." >&2
        exit 1
    fi
done

if [ "$#" -ne 3 ]; then
    echo "Gebruik: $0 <omgeving> <role_id> <email>" >&2
    echo "Voorbeeld: $0 test 99 gast@example.com" >&2
    exit 1
fi

OMGEVING=$1
ROLE_ID=$2
EMAIL=$3
CONFIG_FILE=".invite-${OMGEVING}-config"

if [ ! -f "$CONFIG_FILE" ]; then
    echo "Fout: Configuratiebestand '$CONFIG_FILE' voor de omgeving '$OMGEVING' niet gevonden." >&2
    echo "" >&2
    echo "Maak een configuratiebestand aan voor deze service/omgeving:" >&2
    echo "Bestandsnaam: $CONFIG_FILE" >&2
    echo "Inhoud:" >&2
    echo "--------------------------------------" >&2
    echo "BASE_URL=https://invite.${OMGEVING}.surfconext.nl" >&2
    echo "API_TOKEN=jouw_${OMGEVING}_token_hier" >&2
    echo "--------------------------------------" >&2
    exit 1
fi

BASE_URL=$(grep '^BASE_URL=' "$CONFIG_FILE" | cut -d'=' -f2- | tr -d '\n\r ')
API_TOKEN=$(grep '^API_TOKEN=' "$CONFIG_FILE" | cut -d'=' -f2- | tr -d '\n\r ')

if [ -z "$BASE_URL" ] || [ -z "$API_TOKEN" ]; then
    echo "Fout: BASE_URL of API_TOKEN ontbreekt in $CONFIG_FILE." >&2
    exit 1
fi

FULL_URL="${BASE_URL}/api/external/v1/invitations"

EXPIRY_DATE=$(date -u -v+30d +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date -u -d "+30 days" +"%Y-%m-%dT%H:%M:%SZ")

PAYLOAD=$(jq -n \
  --arg role_id "$ROLE_ID" \
  --arg email "$EMAIL" \
  --arg expiry "$EXPIRY_DATE" \
  '{
    intendedAuthority: "GUEST",
    invites: [$email],
    roleIdentifiers: [$role_id | tonumber],
    expiryDate: $expiry,
    guestRoleIncluded: true,
    language: "en"
  }')

RESPONSE=$(curl -s -w "%{http_code}" -X POST "$FULL_URL" \
     -H "X-API-TOKEN: $API_TOKEN" \
     -H "Content-Type: application/json" \
     -d "$PAYLOAD")

HTTP_STATUS="${RESPONSE: -3}"
BODY="${RESPONSE::-3}"

if [[ "$HTTP_STATUS" =~ ^20[0-9]$ ]]; then
    echo "Succes! Uitnodiging verstuurd naar $EMAIL voor rol $ROLE_ID."
    echo -n "Url: "
    echo "$BODY" | jq -r '.recipientInvitationURLs[0].invitationURL'
else
    echo "Fout: Kan gast niet uitnodigen in omgeving '$OMGEVING'." >&2
    echo "Status code: $HTTP_STATUS" >&2
    echo "Respons: $BODY" >&2
    exit 1
fi
